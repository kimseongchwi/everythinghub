// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 자격증 관리 테이블
model Certification {
  id          String   @id @default(uuid())
  title       String   // 자격증 명칭
  issuer      String   // 발급 기관
  status      String   // 상태 (취득완료, 준비중 등)
  acquiredAt  DateTime? // 취득일
  sortOrder   Int      @default(0) // 정렬 순서
  
  // 첨부파일 관계
  attachmentId String? @unique
  attachment   Attachment? @relation(fields: [attachmentId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// 첨부파일 관리 테이블
model Attachment {
  id           String   @id @default(uuid())
  originalName String   // 원본 파일명
  fileName     String   // 저장된 파일명
  url          String   // 접근 URL
  size         Int      // 용량
  mimeType     String   // 형식
  
  certification Certification?
  
  createdAt    DateTime @default(now())
}
